#!/usr/bin/env python3
import os
import sys
import atexit
import logging
import tempfile

# Make the `req` package (repo root) and this dir (for `variant`) importable
_here = os.path.dirname(os.path.abspath(__file__))
_root = os.path.dirname(_here)
for _p in (_root, _here):
    if _p not in sys.path:
        sys.path.insert(0, _p)

from req._config import models_config, open_db
from req._loop import run_loop, install_signal_handlers
from req._manager import run as manager_run
from variant import VariantRequest, VariantBatchSession

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s: %(message)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)

WORDLIST_ENV = 'FV_WORDLIST'

USAGE = "usage: ./req <model> [model2 ...] [max_workers] [batch_size] < wordlist"


def read_words(fh):
    words = []
    for line in fh:
        w = line.strip()
        if w:
            words.append(w)
    return words


if __name__ == '__main__':
    args = sys.argv[1:]
    managed = False
    run_id = None
    if args and args[0] == '--managed':
        managed = True
        args = args[1:]
        if not args or not args[0][:1].isdigit():
            print("error: --managed requires a run_id argument")
            sys.exit(2)
        run_id = int(args[0])
        args = args[1:]
    if not args:
        print(USAGE)
        print(f"\navailable models: {', '.join(models_config.keys())}")
        sys.exit(2)

    # Parse: model ... [<num>] [<num>]
    i = 0
    models = []
    while i < len(args) and not (args[i][:1].isdigit() or args[i][:1] == '-'):
        models.append(args[i])
        i += 1

    max_workers = 100
    batch_size_override = None
    rest = []
    if i < len(args):
        try:
            max_workers = int(args[i])
        except ValueError:
            print(f"error: invalid max_workers value: {args[i]}")
            sys.exit(2)
        rest.append(args[i])
        i += 1
    if i < len(args) and (args[i][:1].isdigit() or args[i][:1] == '-'):
        try:
            batch_size_override = int(args[i])
        except ValueError:
            print(f"error: invalid batch_size value: {args[i]}")
            sys.exit(2)
        rest.append(args[i])
        i += 1

    if i < len(args):
        print(f"error: unexpected extra arguments: {' '.join(args[i:])}")
        print(USAGE)
        sys.exit(2)

    bad = [m for m in models if m not in models_config]
    if bad:
        print(f"error: unknown model(s): {', '.join(bad)}")
        print(f"available models: {', '.join(models_config.keys())}")
        sys.exit(2)

    if not models:
        print(f"error: no model specified")
        print(f"available models: {', '.join(models_config.keys())}")
        sys.exit(2)

    if not managed:
        # Read the word list once from stdin and stash it where each managed
        # child can read the full list (children inherit our environment).
        words = read_words(sys.stdin)
        if not words:
            print("error: no words on stdin")
            sys.exit(2)

        fd, path = tempfile.mkstemp(prefix='fv-words-', suffix='.txt',
                                    dir=os.environ.get('TMPDIR') or None)
        with os.fdopen(fd, 'w') as f:
            f.write('\n'.join(words))
        os.environ[WORDLIST_ENV] = path
        atexit.register(lambda: os.path.exists(path) and os.remove(path))

        with open_db('w') as conn:
            conn.executemany("insert or ignore into models values (?)",
                             ((k,) for k in models_config.keys()))

        manager_run(models, extra_args=rest,
                    child_cmd=[sys.executable, os.path.abspath(__file__)])
    else:
        path = os.environ.get(WORDLIST_ENV)
        if not path or not os.path.exists(path):
            print(f"error: {WORDLIST_ENV} not set or missing")
            sys.exit(2)
        with open(path) as f:
            words = read_words(f)

        install_signal_handlers()

        model_alias = models[0]
        batch_size = batch_size_override or models_config[model_alias]['batch_size']

        run = VariantBatchSession(model_alias, batch_size, run_id, words)
        rc = run_loop(run, VariantRequest, max_workers)
        sys.exit(rc)
